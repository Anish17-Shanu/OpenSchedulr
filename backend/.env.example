SPRING_PROFILES_ACTIVE=postgres
DB_URL=jdbc:postgresql://localhost:5432/openschedulr
DB_USERNAME=openschedulr
DB_PASSWORD=openschedulr
DB_DRIVER=org.postgresql.Driver
JWT_SECRET=change-me-change-me-change-me-change-me
JWT_EXPIRATION_MINUTES=480
REDIS_HOST=localhost
REDIS_PORT=6379

# Alternative Neon-style PostgreSQL variables supported by application-postgres.yml
PGHOST=localhost
PGDATABASE=openschedulr
PGUSER=openschedulr
PGPASSWORD=openschedulr
PGSSLMODE=disable
PGCHANNELBINDING=disable
