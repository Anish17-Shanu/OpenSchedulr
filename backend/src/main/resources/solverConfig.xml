<?xml version="1.0" encoding="UTF-8"?>
<solver xmlns="https://www.optaplanner.org/xsd/solver"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="https://www.optaplanner.org/xsd/solver https://www.optaplanner.org/xsd/solver/solver.xsd">
    <solutionClass>com.openschedulr.scheduling.solver.SchedulePlan</solutionClass>
    <entityClass>com.openschedulr.scheduling.solver.LectureAssignment</entityClass>
    <scoreDirectorFactory>
        <constraintProviderClass>com.openschedulr.scheduling.solver.ScheduleConstraintProvider</constraintProviderClass>
    </scoreDirectorFactory>
    <termination>
        <spentLimit>10s</spentLimit>
    </termination>
</solver>
